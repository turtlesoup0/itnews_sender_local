# 뉴스 서비스 계정 정보
NEWS_SERVICE_USER_ID=your_news_service_id
NEWS_SERVICE_PASSWORD=your_news_service_password

# 이메일 서비스 SMTP 설정
EMAIL_SERVICE_USER=your_email@example.com
EMAIL_SERVICE_APP_PASSWORD=your_email_app_password

# 수신자 이메일
RECIPIENT_EMAIL=admin@example.com

# 타임존 (선택사항)
TZ=Asia/Seoul

# Parameter Store 설정 (로컬 개발용)
# Lambda 환경에서는 Parameter Store에서 자동 로드됨
UNSUBSCRIBE_FUNCTION_URL=https://your-function-url.lambda-url.ap-northeast-2.on.aws
ADMIN_EMAIL=your_admin@email.com
UNSUBSCRIBE_SECRET=your_secret_key_here
